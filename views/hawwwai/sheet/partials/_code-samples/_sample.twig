
{# GESTION DES RATING LABELS NON OFFICIELS #}

{% if object.data.ratings.labels is defined %}
    {% for label in object.data.ratings.labels %}
        {% if label.type is defined %}


            {% if label.type == '99.06.03.07.08'  %} {# Fleur de soleil #}
                {% for image in thesaurus.images %}
                    {% if image.code == label.type %}
                        {% for i in 1..image.repeated %}
                            <img src={{image.url}} >
                        {% endfor %}
                    {% endif %}
                {% endfor %}
            {% endif %}


            {% if label.type == '06.03.06.05' %} {# Gault Millau #}
                {% if label.ratingLevels[0].ratingLevel is defined %}
                    {% if label.ratingLevels[0].ratingLevel == '99.06.03.06.05.02' %}
                        {# 1..5 toque(s)  image non existante dans thesaurus #}
                    {% endif %}
                {% endif %}
            {% endif %}


        {% endif %}
    {% endfor %}
{% endif %}


{# metadata #}
    {% if formated_object.microData.type == 'http://schema.org/Event'
        and object.data.periods is not empty
        and object.data.periods[0].startDate is defined %}
        <meta itemprop="startDate" content="{{ object.data.periods[0].startDate }}">
    {% endif %}