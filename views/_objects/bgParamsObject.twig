{% extends '_objects/visualModifier.twig' %}

{% block content %}
    {% if no_padding == 0 %}
        {% set spaceBetween = 30 %}
    {% else %}
        {% set spaceBetween = 0 %}
    {% endif %}
    <div class="woody-component woody-component-{% block woodyBlockType %}{% endblock %} tpl_{% block indexClass %}{% endblock %} {{ display.classes|default }}{{ display.background_img or display.classes ? ' isRel' }}{{ display.background_img or display.classes ? ' padd-all-md' }}{{ display.background_img ? ' has-bgimg' }}{% if swiperOut and items|length > swiperOut %} swiperOut{% endif %} {{ customClasses|default }}{{ mobile_behaviour.hide_for_mobile ? ' show-for-xmedium' }}"{% if not desequalize %} data-equalizer="data-equalizer"{% endif %}>
        {% if display.background_img %}
            {% include '_objects/bgImageObject.twig' with {
                'img': display.background_img,
            } %}
            <div class="content isRel">
        {% endif %}

        {% if alert %}
            <div class="empty-section admin-only">
                <div class="empty-message isAbs">
                    <p>{{ alert|default }}</p>
                </div>
            </div>
        {% endif %}
        {% block woodyComponentContent %}{% endblock %}

        {% if background_img %}
            </div>
        {% endif %}
    </div>

{% endblock %}
