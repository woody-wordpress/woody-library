{# Phones & fax reveal button #}
{% if (phones is not empty or fax is not null) and contractsLevels.sidebar.phone %}
    <!-- // Phones -->
    <li class="list-group-item sidebar-contact-phones">
        <dl class="row" reveal>
            {% if contractsLevels.hidephones %}
                <div class="phone-infos delete-when-reveal reveal-button">
                    {{ 'SECTIONS.TOURISM.SHEET.PHONE_REVEAL'|trans }}
                </div>
            {% endif %}
            {# First phone if available #}
            {% if phones is not empty or fax is not empty %}
                <dt class="col-xs-2">
                    <span class="icon-font-phone plo-fonticon"></span>
                </dt>

                <dd class="col-xs-10 _plu-hard--left">
                    {% if phones[0] is defined and phones[0] is not empty %}
                        {% if contractsLevels.hidephones %}
                            <div class="main-tel">
                                <div class="phone-link reveal-button delete-when-reveal"
                                    interact event-type="SHEET_REVEAL_PHONE"
                                    analytics-mediaveille>

                                    {{ phones[0]|hideNumber(2) }}<span class="hidden-number">▒▒</span>
                                </div>
                                <a class="phone-link reveal-content" itemprop="telephone" data-rel="external" href="tel:{{ phones[0] }}">{{ phones[0]|beautyNumber }}</a>
                            </div>
                        {% else %}
                            <div class="main-tel">
                                <a class="phone-link" itemprop="telephone" data-rel="external" href="tel:{{ phones[0] }}">{{ phones[0]|beautyNumber }}</a>
                            </div>
                        {% endif %}
                    {% endif %}

                    {% if phones[1] is defined and phones[1] is not empty %}
                        {% if contractsLevels.hidephones %}
                            <div class="secondary-tel">
                                <div class="phone-link reveal-button delete-when-reveal"
                                    interact event-type="SHEET_REVEAL_PHONE"
                                    analytics-mediaveille>
                                    {{ phones[1]|hideNumber(2) }}<span class="hidden-number">▒▒</span>
                                </div>
                                <a class="phone-link reveal-content" itemprop="telephone" data-rel="external" href="tel:{{ phones[1] }}">{{ phones[1]|beautyNumber }}</a>
                            </div>
                        {% else %}
                            <div class="secondary-tel">
                                <a class="phone-link" itemprop="telephone" data-rel="external" href="tel:{{ phones[1] }}">{{ phones[1]|beautyNumber }}</a>
                            </div>
                        {% endif %}
                    {% endif %}

                    {# Fax if available #}
                    {% if fax is not empty %}
                        {% if contractsLevels.hidephones %}
                            <div class="fax" itemprop="faxNumber" reveal>
                                <div class="phone-link reveal-button delete-when-reveal"
                                    interact event-type="SHEET_REVEAL_PHONE"
                                    analytics-mediaveille>
                                    {{ 'SECTIONS.TOURISM.SHEET.FAX'|trans }}:&nbsp;{{ fax|hideNumber(2) }}
                                    <span class="hidden-number">▒▒</span>
                                </div>
                                <div class="phone-link reveal-content" itemprop="telephone">{{ 'SECTIONS.TOURISM.SHEET.FAX'|trans }}:&nbsp;{{ fax|beautyNumber }}</div>
                            </div>
                        {% else %}
                            <div class="fax" itemprop="faxNumber">
                                <div class="phone-link" itemprop="telephone">{{ 'SECTIONS.TOURISM.SHEET.FAX'|trans }}:&nbsp;{{ fax|beautyNumber }}</div>
                            </div>
                        {% endif %}
                    {% endif %}

                    {# {% if contractsLevels.hidephones %}
                        <div class="phone-infos delete-when-reveal">
                            {{ 'SECTIONS.TOURISM.SHEET.PHONE_REVEAL'|trans }}
                        </div>
                    {% endif %} #}
                </dd>
            {% endif %}
        </dl>
    </li>
{% endif %}


{# Always shown content #}
{% if contractsLevels.sidebar.website and websites is not empty %}
    <!-- // Website -->
    <li class="list-group-item sidebar-contact-websites">
        <dl class="row">
            <dt class="col-xs-2">
                <span class="icon-font-globe plo-fonticon"></span>
            </dt>

            <dt class="col-xs-10 _plu-hard--left">
                {% for website in websites %}
                    <div class="website ellipsis"
                        analytics-mediaveille
                        interact event-type="WEBSITE_TOURISTIC_PROVIDER">
                        <a data-type="URL" class='nowrap' itemprop="url" href="{{ website|default }}" target="_blank">{{ website|simpleURL }}</a>
                    </div>
                {% endfor %}
            </dt>
        </dl>
    </li>
{% endif %}
