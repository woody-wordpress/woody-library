{% if contractsLevels.content.description
    or contractsLevels.content.slogan
    or formated_object.passDescription|default
    or formated_object.groupsDescription.description|default
    or formated_object.accessPoints|default
    or formated_object.environmentPoints|default
    or contractsLevels.content.capacities
    or formated_object.thalassoData|default
    or contractsLevels.content.labels
    or contractsLevels.content.handicap
    or (formated_object.langs|default and contractsLevels.content.lang)
    or contractsLevels.content.docs %}

    {% if contractsLevels.content.description and formated_object.passDescription|default %}
    <section id="pass-description" class="tourism-detail-pass-description panel panel-default s-stripes s-stripes--contrast row list-group-item">
        <dl>
            <dt class="col-xs-12 col-sm-12 _plu-push--tiny"><span class="pl-heading">{{ 'Notre offre « Chartrexpérience, Le Pass’ »' }}</span></dt>
            <dd class="col-xs-12 col-sm-12"><span>{{ formated_object.passDescription }}</span></dd>
        </dl>
    </section>
    {% endif %}

    <section id="description" class="tourism-detail-description panel panel-default s-stripes s-stripes--contrast row">

        <ul class="list-group stripes-odd">
            {# Description #}
            {% if (contractsLevels.content.description and formated_object.description|default or formated_object.passDescription|default) or (contractsLevels.content.slogan and formated_object.slogan|default) %}
                <li class="list-group-item">
                    {# Description__title #}
                    {% if formated_object.slogan|default and contractsLevels.content.slogan %}
                        <p class="slogan-description _plu-emphasis--high {{ formated_object.description is null ? '_plu-flush' : '' }}">{{ formated_object.slogan|nl2br }}</p>
                    {% endif %}

                    {# Description__body #}
                    {% if contractsLevels.content.description and formated_object.description|default %}
                        <span class="establishment-description" itemprop="description">
                            {{ formated_object.description|raw|nl2br }}
                        </span>
                    {% endif %}

                    {# Description__further_informations #}
                    {% if contractsLevels.content.description and formated_object.practicalInfos|default %}
                        <div class="establishment-description _plu-push-top--small">
                            {{ formated_object.practicalInfos|raw|nl2br }}
                        </div>
                    {% endif %}

                    {# if set a See More button for description, add event #}
                    {# interact event-type="SHEET_DESCRIPTION_SEE_MORE" #}
                </li>
            {% endif %}

            {# ChefName #}
            {% if formated_object.bordereau in ['RES'] and formated_object.chefName|default %}
            <li class="list-group-item">
                <dl class="row">
                    <dt class="col-xs-12 col-sm-3 _plu-push--tiny"><span class="pl-heading">{{ 'Chef'|trans }}</span></dt>
                    <dd class="col-xs-12 col-sm-9">
                        {{ formated_object.chefName }}
                    </dd>
                </dl>
            </li>
            {% endif %}

            {# Good Deals Description #}
            {% if formated_object.goodDealsDescription|default %}
            <li class="list-group-item">
                <dl class="row">
                    <dt class="col-xs-12 col-sm-3 _plu-push--tiny"><span class="pl-heading">{{ 'SECTIONS.TOURISM.SHEET.DEALS.DEALS'|trans }}</span></dt>
                    <dd class="col-xs-12 col-sm-9">
                        {{ formated_object.goodDealsDescription }}
                    </dd>
                </dl>
            </li>
            {% endif %}

            {# Trip #}
            {% if formated_object.bordereau in ['PRD','ITI'] %}
                {% include TWIG.TRIP_SECONDARY %}
            {% endif %}

            {# accessPoints #}
            {% if formated_object.accessPoints|default  %}
                <li class="list-group-item">
                    <dl class="row">

                        <dt class="col-xs-12 col-sm-3 _plu-push--tiny"><span class="pl-heading">{{ 'SECTIONS.TOURISM.SHEET.ACCESS'|trans }}</span></dt>

                        <dd class="col-xs-12 col-sm-9">
                            <ul class="plo-list-bare">
                                {% for access in formated_object.accessPoints %}
                                    <li>
                                        <span class="">{{ access._type }}</span>
                                        {% if access._name|default %}
                                            &nbsp;:&nbsp;
                                            <span class="pl-heading">{{ access._name }}</span>
                                        {% endif %}
                                        {% if access._distance is defined %}
                                            {{ 'GLOBAL.AT' | trans }}
                                            <span class="pl-heading">
                                                {{ access._distance| number_format}}
                                                {{ access._distanceUnit }}
                                            </span>
                                        {% endif %}
                                    </li>
                                {% endfor %}
                            </ul>
                        </dd>
                    </dl>
                </li>
            {% endif %}

            {# environmentPoints #}
            {% if formated_object.environmentPoints|default and contractsLevels.content.environment %}
                <li class="list-group-item">
                    <dl class="row">

                        <dt class="col-xs-12 col-sm-3 _plu-push--tiny"><span class="pl-heading">{{ 'SECTIONS.TOURISM.SHEET.ENVIRONMENT'|trans }}</span></dt>

                        <dd class="col-xs-12 col-sm-9">
                            <ul class="plo-list-bare">
                                {% for env in formated_object.environmentPoints %}
                                    <li>
                                        <span class="">{{ env._type }}</span>
                                        {% if env._name|default  %}
                                            &nbsp;:&nbsp;
                                            <span class="pl-heading">{{ env._name }}</span>
                                        {% endif %}
                                        {% if env._distance|default %}
                                            {{ 'GLOBAL.AT' | trans }}
                                            <span class="pl-heading">
                                                {{ env._distance| number_format}}
                                                {{ env._distanceUnit }}
                                            </span>
                                        {% endif %}
                                    </li>
                                {% endfor %}
                            </ul>
                        </dd>
                    </dl>
                </li>
            {% endif %}


            {# Capacities #}
            {% if contractsLevels.content.capacities and ( formated_object.capacities|length > 1 or not formated_object.capacities.groupCapacities|default) %}
                <li class="list-group-item">
                    <dl class="row">

                        <dt class="col-xs-12 col-sm-3 _plu-push--tiny"><span class="pl-heading">{{ 'SECTIONS.TOURISM.SHEET.CAPACITY'|trans }}</span></dt>

                        <dd class="col-xs-12 col-sm-9">
                            <ul class="plo-list-bare plo-list-even">
                                {% for typedCapacity in formated_object.capacities %}
                                    {% for capacity in typedCapacity %}
                                        {% if capacity.type|default and capacity.type != '99.14.01.07' %} {# no groupCapacities #}
                                            {% if capacity.capacity|default %}
                                                <li class="{{capacity.type}}">
                                                    {% if thesaurus.fulldictionary[capacity.type]|default %}
                                                        {# Si c'est une pièce ou une chambre #}
                                                        {# {% if capacity.unitCapacity == '01.03.01.10' or capacity.unitCapacity == '01.03.01.03' %}
                                                            {{ thesaurus.fulldictionary[capacity.unitCapacity] }}
                                                            |
                                                            {{ capacity.capacity }}&nbsp;{{ thesaurus.fulldictionary[capacity.type] }}
                                                        {% else %} #}
                                                            {% if thesaurus.fulldictionary[capacity.type]|default %}
                                                                <span class="_plu-emphasis--high">{{ thesaurus.fulldictionary[capacity.type] }}&nbsp;:&nbsp;</span>
                                                            {% endif %}

                                                            {{ capacity.capacity }}&nbsp;{{ thesaurus.fulldictionary[capacity.unitCapacity] }}
                                                        {# {% endif %} #}
                                                    {% endif %}

                                                    {% if capacity.superficy|default %}
                                                            <span>&bull;&nbsp;{{ 'SECTIONS.TOURISM.SHEET.SUPERFICY'|trans }}&nbsp;:&nbsp;</span>
                                                            {{ capacity.superficy }} m<up>2</up>
                                                    {% elseif capacity.averageSurface|default %}
                                                            <span>&bull;&nbsp;{{ 'SECTIONS.TOURISM.SHEET.AVERAGE_SUPERFICY'|trans }}&nbsp;:&nbsp;</span>
                                                            {{ capacity.averageSurface }} m<up>2</up>
                                                    {% endif %}
                                                </li>
                                            {% elseif capacity.superficy|default %}
                                                <li class="{{capacity.type}}">
                                                    <span class="_plu-emphasis--high">{{ 'SECTIONS.TOURISM.SHEET.SUPERFICY'|trans }}&nbsp;:&nbsp;</span>
                                                    {{ capacity.superficy }} m<up>2</up>
                                                </li>
                                            {% elseif capacity.averageSurface|default %}
                                                <li class="{{capacity.type}}">
                                                    <span class="_plu-emphasis--high">{{ 'SECTIONS.TOURISM.SHEET.AVERAGE_SUPERFICY'|trans }}&nbsp;:&nbsp;</span>
                                                    {{ capacity.averageSurface }} m<up>2</up>
                                                </li>
                                            {% endif %}
                                        {% endif %}
                                    {% endfor %}
                                {% endfor %}
                            </ul>
                        </dd>
                    </dl>
                </li>
            {% endif %} {# End of Capacities #}

            {# Legal Information #}
            {% if object.data.legalInformations|default and options.legalinfos is defined and options.legalinfos and contractsLevels.content.legalInfos %}
                <li class="list-group-item legal-informations">
                    <dl class="row">
                        <dt class="col-xs-12 col-sm-3 _plu-push--tiny"><span class="pl-heading">{{ 'GLOBAL.LEGAL_INFORMATION.LEGAL_INFORMATIONS'|trans }}</span></dt>
                        <dd class="col-xs-12 col-sm-9">
                        {% for information in object.data.legalInformations %}
                            <div>

                                <span class="_plu-emphasis--high">{{ ('GLOBAL.LEGAL_INFORMATION.'~information.type|upper)|trans}}&nbsp;:</span>
                                <span class="">{{ information.value }}</span>
                            </div>
                        {% endfor %}
                        </dd>
                    </dl>
                </li>
            {% endif %}

            {# Langs #}
            {% if contractsLevels.content.lang and formated_object.langs|default %}
                <li class="list-group-item spoken-languages">
                    <dl class="row">

                        <dt class="col-xs-12 col-sm-3 _plu-push--tiny"><span class="pl-heading">{{ 'SECTIONS.TOURISM.SHEET.SPOKEN_LANGUAGES'|trans }}</span></dt>

                        <dd class="col-xs-12 col-sm-9">
                            <ul class="plo-nav md-icon-list">
                                {# parse data.langs #}
                                {% for spokenlang in formated_object.langs %}
                                    <li class="langs-icon"
                                        {% if spokenlang._lang|default %}
                                            tooltip="{{ spokenlang._lang }}"
                                        {% endif %}>
                                        <img width="24"
                                            {% if spokenlang._lang|default %}
                                                alt="{{ spokenlang._lang }}"
                                            {% endif %}
                                                src={{ spokenlang._url }}
                                        />
                                    </li>
                                {% endfor %}
                            </ul>
                        </dd>
                    </dl>
                </li>
            {% endif %} {# End of lang #}


            {# Labels #}
            {% if contractsLevels.content.labels %}
                <li class="list-group-item tourism-labels">
                    <dl class="row">

                        {# <dt class="col-xs-12 col-sm-3 _plu-push--tiny">
                            {% if formated_object.labels.simpleLabels._title|default
                                and thesaurus.fulldictionary[formated_object.labels.simpleLabels._title]|default %}
                                <span class="pl-heading">{{ thesaurus.fulldictionary[formated_object.labels.simpleLabels._title] }}</span>
                            {% endif %}
                        </dt> #}

                        <dd class="col-xs-12">
                            <ul class="nav-inline sheet-labels-list">
                            {% for simplelabel in formated_object.labels.simpleLabels._labels %}
                                {% for image in thesaurus.images %}
                                    {% if image.code == simplelabel.type %}

                                        {# display label #}
                                        <li class="sheet-labels-list_item">
                                            <div class="sheet-labels-list_wrapper">
                                                {% if image.urlInfo|default %}
                                                <a href="{{ image.urlInfo }}">
                                                {% endif %}
                                                    <div class="sheet-labels-list_icon"
                                                        {% if thesaurus.fulldictionary[image.code]|default %}
                                                         tooltip="{{thesaurus.fulldictionary[image.code]}}"
                                                        {% endif %}>

                                                        {% if image.urlHD|default %}
                                                        <img class="{{simplelabel.type}}" alt="{{thesaurus.fulldictionary[image.code]|default}}" src={{ image.urlHD | rcImg(100, 100, 75, 'png', 'clip') }}>
                                                        {% else %}
                                                        <img alt="{{thesaurus.fulldictionary[image.code]|default}}" src={{ image.url | rcImg(100, 100, 75, 'png', 'clip') }}>
                                                        {% endif %}
                                                    </div>
                                                {% if image.urlInfo|default %}
                                                </a>
                                                {% endif %}
                                            </div>
                                        </li>

                                    {% endif %}
                                {% endfor %}
                            {% endfor %}
                            </ul>
                        </dd>
                    </dl>
                </li>
            {% endif %} {# End of labels #}


            {# Tourisme & handicap #}
            {% if contractsLevels.content.handicap %}
                <li class="list-group-item tourism-handicap-labels">
                    <dl class="row">

                        <dt class="col-xs-12 col-sm-3 _plu-push--tiny">
                            {% if formated_object.labels.tourismHandicap._title|default
                                and thesaurus.fulldictionary[formated_object.labels.tourismHandicap._title]|default %}
                                <span class="pl-heading">{{ thesaurus.fulldictionary[formated_object.labels.tourismHandicap._title] }}</span>
                            {% else %}
                                 <span class="pl-heading text-undefined-thesaurus">Handicap</span>
                            {% endif %}

                        </dt>

                        <dd class="col-xs-12 col-sm-9">
                            <ul class="nav-inline sheet-labels-list">
                                {% for label in formated_object.labels.tourismHandicap._formatedLabels|keys %}
                                    {% for image in thesaurus.images %}
                                        {% if image.code == label %}
                                            <li class="sheet-labels-list_item col-xs-3"
                                                {% if thesaurus.fulldictionary[image.code]|default %}
                                                tooltip="{{thesaurus.fulldictionary[image.code]}}"
                                                {% endif %}>

                                                <div class="sheet-labels-list_wrapper">
                                                    {% if formated_object.labels.tourismHandicap._formatedLabels[label]|default
                                                       and formated_object.labels.tourismHandicap._formatedLabels[label] %}
                                                        {# Display label normally #}
                                                        <div class="sheet-labels-list_icon sheet-labels-list_icon-thlabel">
                                                    {% else %}
                                                        {# Display label disabled #}
                                                        <div class="sheet-labels-list_icon sheet-labels-list_icon-thlabel unavailable">
                                                    {% endif %}

                                                        {% if image.urlHD|default %}
                                                        <img src={{ image.urlHD | rcImg(40, 40, 100, 'png', 'clip') }}>
                                                        {% else %}
                                                        <img src={{ image.url | rcImg(40, 40, 100, 'png', 'clip') }}>
                                                        {% endif %}

                                                    </div>
                                                </div>
                                            </li>
                                        {% endif %}
                                    {% endfor %}
                                {% endfor %}
                            </ul>
                        </dd>
                    </dl>
                </li>
            {% endif %} {# End of Tourisme & handicap #}

            {# Pdfs / docs #}
            {% if contractsLevels.content.docs %}
                <li id="download" class="list-group-item">
                    <dl class="row">

                        <dt class="col-xs-12 col-sm-3 _plu-push--tiny">
                            <span class="pl-heading">{{ 'SECTIONS.TOURISM.SHEET.DOCUMENTATION'|trans }}</span>
                        </dt>

                        {% set mapDocs = false %}
                        <dd class="col-xs-12 col-sm-9">
                            <ul class="document-list">
                                {% for document in formated_object.documents %}
                                    <li>
                                        <a {% if document.type == '99.03.01.01' %}
                                            data-type="TRACE"
                                            event-type="SHEET_DOWNLOAD_TRACE"
                                            {% else %}
                                            target="_blank"
                                            data-type="FICHIER"
                                            event-type="SHEET_DOWNLOAD_PDF"
                                            {% endif %}
                                            interact itemprop="url" href={{ document.URL }} download>
                                            <span class="icon-font-download plo-fonticon"></span>
                                            {{ document._name|default }}
                                        </a>
                                    </li>
                                    {% if document.type == '99.03.01.01' %}
                                        {% set mapDocs = true %}
                                    {% endif %}
                                {% endfor %}
                            </ul>
                            {% if object.data.bordereau in ['ITI','PRD'] and mapDocs %}
                                <span class="itinerary-download-text">{{ 'SECTIONS.TOURISM.SHEET.ITINERARY.FILES'|trans }}</span>
                            {% endif %}
                        </dd>
                    </dl>
                </li>
            {% endif %} {# End of Pdfs / docs #}

            {# Audio files #}
            {% if formated_object.audiofiles|default and contractsLevels.content.audios %}
                <li class="list-group-item">
                    <dl class="row">

                        <dt class="col-xs-12 col-sm-3 _plu-push--tiny">
                            <span class="pl-heading">{{ 'SECTIONS.TOURISM.SHEET.AUDIO'|trans }}</span>
                        </dt>

                        <dd class="col-xs-12 col-sm-9">
                            <ul>
                                {% for audio in formated_object.audiofiles %}
                                    <li class="audio-element">
                                        <div class="audio-element-wrapper">
                                            <audio rc-media rc-media-src="{{audio.URL}}" rc-media-id="" width="100%" controls></audio>
                                        </div>
                                    </li>
                                {% endfor %}
                            </ul>
                        </dd>
                    </dl>
                </li>
            {% endif %}
        </ul>
    </section>

    {% if formated_object.dataCustomers|default or formated_object.groupsDescription.description|default
        or (contractsLevels.content.capacities and formated_object.capacities|default and formated_object.capacities.groupCapacities|default)
        or formated_object.sfGolfCourse|default or formated_object.sfBeachType|default %}
    <section id="groups" class="tourism-detail-groups panel panel-default s-stripes s-stripes--contrast row">
        <ul class="list-group stripes-odd">

            {# dataCustomers #}
            {% if formated_object.dataCustomers|default and contractsLevels.content.description %}
                <li class="list-group-item">
                    <dl class="row">
                        <dt class="col-xs-12 col-sm-3 _plu-push--tiny">
                            <span class="pl-heading">{{ formated_object.dataCustomers.label }}</span>
                        </dt>

                        <dd class="col-xs-12 col-sm-9">
                            <ul class="plo-list-bare">

                                {% if formated_object.dataCustomers.showIndividuals|default %}
                                    <li><span>{{ 'SECTIONS.TOURISM.SHEET.INDIVIDUALS' | trans}}</span></li>
                                {% endif %}

                                {% for customer in formated_object.dataCustomers.customers %}
                                    <li><span>{{ customer|default }}</span></li>
                                {% endfor %}
                            </ul>
                        </dd>
                    </dl>
                </li>
            {% endif %}

            {# groupDescription #}
            {% if formated_object.groupsDescription.description|default and contractsLevels.content.description %}
                <li class="list-group-item">
                    <dl class="row">
                        <dt class="col-xs-12 col-sm-3 _plu-push--tiny">
                            <span class="pl-heading">{{ formated_object.groupsDescription.label }}</span>
                        </dt>

                        <dd class="col-xs-12 col-sm-9">
                            <span>{{ formated_object.groupsDescription.description }}</span>
                        </dd>
                    </dl>
                </li>
            {% endif %}

            {# Group Capacities #}
            {% if contractsLevels.content.capacities and formated_object.capacities|default and formated_object.capacities.groupCapacities|default %}
                <li class="list-group-item">
                    <dl class="row">

                        <dt class="col-xs-12 col-sm-3 _plu-push--tiny"><span class="pl-heading">{{ formated_object.capacities.groupCapacities[0]._type|default('SECTIONS.TOURISM.SHEET.GROUPS_VISITS'|trans) }}</span></dt>

                        <dd class="col-xs-12 col-sm-9">
                            <ul class="plo-list-bare plo-list-even">
                                {% for capacity in formated_object.capacities.groupCapacities %}
                                    {% if capacity.type|default %}
                                        {% if capacity.capacity|default %}
                                            <li class="{{capacity.type}}">
                                                {% if thesaurus.fulldictionary[capacity.unitCapacity]|default %}
                                                    {{ capacity.capacity }}&nbsp;

                                                    {# dev spec for bethune ?? hide capacité des personnes #}
                                                    {{ thesaurus.fulldictionary[capacity.unitCapacity] }}
                                                {% endif %}
                                            </li>
                                        {% endif %}
                                    {% endif %}
                                {% endfor %}
                            </ul>
                        </dd>
                    </dl>
                </li>
            {% endif %}

            {# sfBeachType #}
            {% if formated_object.sfBeachType|default %}
                <li class="list-group-item">
                    <dl class="row">
                        <dt class="col-xs-12 col-sm-3 _plu-push--tiny">
                            <span class="pl-heading">{{ formated_object.sfBeachType._label|default(formated_object.sfBeachType.label) }}</span>
                        </dt>
                        <dd class="col-xs-12 col-sm-9">
                            <ul class="plo-list-bare">
                                {% for beachType in formated_object.sfBeachType.data %}
                                    <li><span>{{ beachType._type|default }}</span></li>
                                {% endfor %}
                            </ul>
                        </dd>
                    </dl>
                </li>
            {% endif %}

            {# sfGolfCourse #}
            {% if formated_object.sfGolfCourse|default %}
                <li class="list-group-item">
                    <dl class="row">
                        <dt class="col-xs-12 col-sm-3 _plu-push--tiny">
                            <span class="pl-heading">{{ formated_object.sfGolfCourse._label|default(formated_object.sfGolfCourse.label) }}</span>
                        </dt>
                        <dd class="col-xs-12 col-sm-9">
                            <ul class="plo-list-bare">
                                {% for golfCourse in formated_object.sfGolfCourse.data %}
                                    <li {% if not loop.last %}class="_plu-push"{% endif %}>
                                        <div>{{ formated_object.sfGolfCourse.labels._sfGolfCourseHolesCount|default }} : {{ golfCourse.sfGolfCourseHolesCount|default }}</div>
                                        <div>{{ formated_object.sfGolfCourse.labels._sfGolfCoursePar|default }} : {{ golfCourse.sfGolfCoursePar|default }}</div>
                                        <div>{{ formated_object.sfGolfCourse.labels._sfGolfCourseLength|default }} : {{ golfCourse.sfGolfCourseLength|default }}</div>
                                    </li>
                                {% endfor %}
                            </ul>
                        </dd>
                    </dl>
                </li>
            {% endif %}
        </ul>
    </section>
    {% endif %}


    {# thalasso #}
    {% if formated_object.thalassoData|default %}
    <section id="thalasso" class="panel panel-default row">
        <li class="list-group-item">
            <dl class="row">

                <dt class="col-xs-12 col-sm-3 _plu-push--tiny"><span class="pl-heading">{{ formated_object.thalassoData._label }}</span></dt>

                <dd class="col-xs-12 col-sm-9">
                    <ul class="plo-list-bare">
                        {% for thalassoDesc in formated_object.thalassoData.data %}
                            <li class="_plu-push--tiny thalasso-item">
                                <div class="_plu-emphasis--high">{{ thalassoDesc._type }}</div>
                                {% if thalassoDesc._desc|default  %}
                                    <div class="">{{ thalassoDesc._desc|raw }}</div>
                                {% endif %}
                            </li>
                        {% endfor %}
                    </ul>
                </dd>
            </dl>
        </li>
    </section>
    {% endif %}

    {% include TWIG.MORE_NAV %}

{% elseif object.data.multimedia|default %}

    {% include TWIG.MORE_NAV %}

{% endif %}
